# ── Backend API ──────────────────────────────────────────────────────────────
# Base URL of the FastAPI backend. Used for session sync, history & analytics.
# Local dev default is http://localhost:8000. When deploying, set this to your
# deployed backend (e.g. https://your-api.onrender.com). If unreachable, the app
# still works fully offline (localStorage) and shows an "offline" banner.
VITE_API_URL=http://localhost:8000

# Legacy alias for VITE_API_URL (still honored if VITE_API_URL is unset).
VITE_BACKEND_URL=http://localhost:8000

# ── Feature flags ────────────────────────────────────────────────────────────
VITE_APP_VERSION=1.0.0
VITE_ENABLE_VOICE=true
VITE_ENABLE_ANALYTICS=true
VITE_POSE_CONFIDENCE=0.7
